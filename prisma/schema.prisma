// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 認証関連（NextAuth.js）
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ユーザー
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(MEMBER)
  department    String?
  position      String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  announcements Announcement[]
  manualPages   ManualPage[]
  helpdeskLogs  HelpdeskLog[]
  questions     Question[]
}

enum Role {
  ADMIN   // 管理者（お知らせ投稿・編集・削除可能）
  MEMBER  // 一般社員（閲覧のみ）
}

// お知らせ
model Announcement {
  id           String   @id @default(cuid())
  title        String
  content      String   @db.Text
  summary      String?  @db.Text  // AI要約（一覧表示用）
  category     String   @default("一般")
  organization String   @default("")
  important    Boolean  @default(false)
  isDraft      Boolean  @default(false)
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  slackSent    Boolean  @default(false)
}

// お知らせカテゴリマスタ
model AnnouncementCategoryMaster {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("bg-gray-100 text-gray-700")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 会社情報ページ（基本情報・MVV・事業所一覧など固定ページ）
model CompanyInfoPage {
  id             String            @id @default(cuid())
  slug           String            @unique  // "basic", "mvv", "offices", etc.
  title          String
  content        String            @db.Text @default("")
  embedUrl       String?           // 外部サイト埋め込みURL
  urls           Json              @default("[]") // [{label, url}]
  updatedAt      DateTime          @updatedAt
  updatedBy      String?           // 最終更新者名
  // 下書きフィールド
  draftContent   String?           @db.Text
  draftEmbedUrl  String?
  draftUrls      Json?
  draftAuthorId  String?
  draftUpdatedAt DateTime?
  files          CompanyInfoFile[]
}

model CompanyInfoFile {
  id         String          @id @default(cuid())
  name       String          // 表示ファイル名
  storedName String          // サーバー上のファイル名
  url        String          // /uploads/xxx
  size       Int
  mimeType   String
  pageId     String
  page       CompanyInfoPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  uploadedBy String?
  isDraft    Boolean         @default(false) // trueの場合は下書きファイル
}

// 規程カテゴリ（基本・経営・組織・人事・総務・経理・業務）
model RegulationCategory {
  id          String       @id @default(cuid())
  name        String
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  regulations Regulation[]
}

// 規程（PDF管理）
model Regulation {
  id            String             @id @default(cuid())
  name          String
  fileName      String
  storedName    String
  url           String
  size          Int
  order         Int                @default(0)
  categoryId    String
  category      RegulationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  textContent   String?            @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  uploadedBy    String?
  helpdeskNodes HelpdeskNode[]
}

// ヘルプデスク：ツリーノード（最大10階層）
model HelpdeskNode {
  id           String         @id @default(cuid())
  label        String         // 選択肢テキスト（例: 「労務・人事」）
  question     String?        // この選択後に表示する質問文（例: 「何について確認しますか？」）
  order        Int            @default(0)
  depth        Int            @default(0) // 0 = ルート
  parentId     String?
  parent       HelpdeskNode?  @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     HelpdeskNode[] @relation("NodeTree")
  // リーフノード用
  answerText   String?        @db.Text   // カスタム回答テキスト
  manualPageId String?
  manualPage   ManualPage?    @relation(fields: [manualPageId], references: [id], onDelete: SetNull)
  regulationId String?
  regulation   Regulation?    @relation(fields: [regulationId], references: [id], onDelete: SetNull)
  nodeType     String         @default("choice")
  useAiAnswer  Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// 部門マスタ
model Department {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// マニュアル：大項目
model ManualCategory {
  id          String          @id @default(cuid())
  name        String          // 例：「営業マニュアル」
  description String?
  department  String?         // 管掌部門
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sections    ManualSection[]
}

// マニュアル：中項目
model ManualSection {
  id          String       @id @default(cuid())
  name        String       // 例：「顧客対応」
  description String?
  order       Int          @default(0)
  categoryId  String
  category    ManualCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  pages       ManualPage[]
}

// カスタムコンテンツセクション（会社情報と同形式で自由に追加できるセクション）
model ContentSection {
  id          String               @id @default(cuid())
  name        String               // サイドバー表示名（例: "社員ハンドブック"）
  slug        String               @unique  // URL用スラッグ（例: "handbook"）
  order       Int                  @default(0)
  hidden      Boolean              @default(false) // trueにするとサイドバーから非表示
  // 使用するコンテンツタイプ（セクション作成時に選択）
  enableText  Boolean              @default(true)  // 本文
  enableFiles Boolean              @default(true)  // 添付ファイル
  enableEmbed Boolean              @default(true)  // 外部サイト埋め込み
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  pages       ContentSectionPage[]
}

// カスタムセクションのサブページ
model ContentSectionPage {
  id        String               @id @default(cuid())
  sectionId String
  section   ContentSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  slug      String               // ページ識別子
  title     String
  content   String               @db.Text @default("")
  embedUrl  String?
  urls      Json                 @default("[]")
  order     Int                  @default(0)
  updatedAt DateTime             @updatedAt
  updatedBy String?
  // 下書きフィールド
  draftContent   String?         @db.Text
  draftEmbedUrl  String?
  draftUrls      Json?
  draftAuthorId  String?         // 下書き作成者のユーザーID
  draftUpdatedAt DateTime?
  files     ContentSectionFile[]

  @@unique([sectionId, slug])
}

// カスタムセクションの添付ファイル
model ContentSectionFile {
  id         String             @id @default(cuid())
  name       String
  storedName String
  url        String
  size       Int
  mimeType   String
  pageId     String
  page       ContentSectionPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  uploadedBy String?
  isDraft    Boolean            @default(false) // trueの場合は下書きファイル（下書き作成者のみ表示）
}

// ヘルプデスク操作履歴
model HelpdeskLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  pathLabels   Json
  userInputs   Json?
  searchTerms  Json?
  contextRegs  Json?
  contextPages Json?
  aiAnswer     String?  @db.Text
  createdAt    DateTime @default(now())
}

// マニュアル：小項目（本文）
model ManualPage {
  id              String          @id @default(cuid())
  title           String
  content         String          @db.Text
  order           Int             @default(0)
  sectionId       String
  section         ManualSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  authorId        String
  author          User            @relation(fields: [authorId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  // 下書きフィールド
  isDraft         Boolean         @default(false)
  draftTitle      String?
  draftContent    String?         @db.Text
  draftAuthorId   String?
  draftUpdatedAt  DateTime?
  helpdeskNodes   HelpdeskNode[]
  manualUpdateTasks ManualUpdateTask[]
}

// ========== AI Q&A システム ==========

// ユーザーの質問
model Question {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    String    @db.Text
  status      String    @default("NEW") // NEW, AI_ANSWERED, FOLLOWUP, ESCALATED, VERIFYING, MANAGER_REPLY, CLOSED
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  answers     Answer[]
  followUps   FollowUp[]
  verification Verification?
  manualUpdateTasks ManualUpdateTask[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// AI生成回答
model Answer {
  id          String    @id @default(cuid())
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerText  String    @db.Text
  sourceUrls  Json      @default("[]") // [{documentName, url, pageNumber}]
  aiModel     String    @default("claude") // claude, gemini
  createdAt   DateTime  @default(now())

  @@index([questionId])
}

// 再質問（フォローアップ）
model FollowUp {
  id          String    @id @default(cuid())
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  retryCount  Int
  followUpQuestion String @db.Text
  followUpAnswer    String @db.Text
  createdAt   DateTime  @default(now())

  @@index([questionId])
}

// 正誤確認
model Verification {
  id          String    @id @default(cuid())
  questionId  String    @unique
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  result      String    // CORRECT, INCORRECT
  comment     String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([questionId])
}

// マニュアル修正タスク
model ManualUpdateTask {
  id          String    @id @default(cuid())
  questionId  String
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  manualPageId String?
  manualPage  ManualPage? @relation(fields: [manualPageId], references: [id], onDelete: SetNull)
  reason      String    @db.Text
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  assigneeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
}
